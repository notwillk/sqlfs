Project inventory {
  database_type: 'SQLite'
  Note: 'Product inventory with categories, suppliers, and stock levels'
}

enum product_status {
  active
  discontinued
  out_of_stock
}

enum unit {
  each
  kg
  litre
  box
}

Table categories {
  name        varchar [not null]
  slug        varchar [not null, unique]
  description text
  parent_pk   varchar
}

Table suppliers {
  name         varchar [not null]
  contact_name varchar
  email        varchar
  phone        varchar
  country      varchar [not null]
  active       boolean [default: true]
}

Table products {
  sku          varchar        [not null, unique]
  name         varchar        [not null]
  description  text
  category_pk  varchar        [not null]
  supplier_pk  varchar        [not null]
  unit         unit           [not null, default: 'each']
  unit_price   real           [not null]
  status       product_status [not null, default: 'active']
}

Table stock_levels {
  product_pk  varchar [not null]
  warehouse   varchar [not null]
  quantity    integer [not null]
  reorder_at  integer
  updated_at  varchar
}
